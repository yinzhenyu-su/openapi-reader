{
  "name": "openapi-reader",
  "version": "0.4.0",
  "description": "CLI tool for LLM-friendly OpenAPI document querying",
  "repository": {
    "type": "git",
    "url": "https://github.com/yinzhenyu-su/openapi-reader"
  },
  "type": "module",
  "bin": {
    "openapi-reader": "dist/index.js"
  },
  "scripts": {
    "build": "npm run generate:skill && tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "npm run generate:skill",
    "generate:skill": "node scripts/generate-project-skill.mjs"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "commander": "^13.1.0",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.14.1",
    "@vitest/coverage-v8": "^4.1.7",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.4.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
